{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "portfolio-peem",
  "main": "src/worker.ts",
  "compatibility_date": "2026-06-03",
  "observability": {
    "enabled": true
  },
  "assets": {
    "binding": "ASSETS",
    "run_worker_first": [
      "/api/contact"
    ],
    "not_found_handling": "single-page-application"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
