          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="edgeNginxApi" value="proxy_pass http://api:4000" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#059669;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#374151;" edge="1" parent="1" source="nginx" target="api">
