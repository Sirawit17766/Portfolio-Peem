          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="flowText" value="Request flow: User opens api.zxcvbn.online - Cloudflare resolves domain - Server receives port 80 - Nginx proxies to API - API reads/writes MongoDB - MongoDB persists data in volume." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#111827;strokeColor=#111827;fontColor=#FFFFFF;fontSize=14;arcSize=8;" vertex="1" parent="1">
