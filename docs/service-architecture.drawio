        <mxCell id="edgeCloudflareServer" value="DNS points to IP" style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#F97316;strokeWidth=2;endArrow=block;endFill=1;fontSize=12;fontColor=#374151;" edge="1" parent="1" source="cloudflare" target="server">
