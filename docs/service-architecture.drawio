        </mxCell>

        <mxCell id="mongo" value="MongoDB Container&lt;br&gt;&lt;font style=&quot;font-size: 12px;&quot;&gt;Database&lt;br&gt;Internal port 27017&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ECFDF3;strokeColor=#16A34A;fontColor=#14532D;fontSize=16;fontStyle=1;arcSize=12;shadow=1;" vertex="1" parent="1">
