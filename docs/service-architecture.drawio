        <mxCell id="note1" value="External traffic can only enter through Nginx on port 80." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#FEF2F2;strokeColor=#EF4444;fontColor=#7F1D1D;fontSize=13;" vertex="1" parent="1">
