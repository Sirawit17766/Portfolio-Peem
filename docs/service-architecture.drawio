        </mxCell>

        <mxCell id="note2" value="API and MongoDB are internal services inside api_network." style="shape=note;whiteSpace=wrap;html=1;backgroundOutline=1;darkOpacity=0.05;fillColor=#F0FDFA;strokeColor=#14B8A6;fontColor=#134E4A;fontSize=13;" vertex="1" parent="1">
