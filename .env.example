PORT=4000
BLOG_STORAGE=memory

# Use these values when BLOG_STORAGE=mongo
MONGODB_URI=mongodb://portfolio_api:CHANGE_ME_STRONG_PASSWORD@127.0.0.1:27017/portfolio_blog?authSource=admin
MONGODB_DB_NAME=portfolio_blog
MONGODB_COLLECTION=posts

# Production hardening
CORS_ORIGINS=https://zxcvbn.online,https://www.zxcvbn.online,https://portfolio-mheepooh.online,https://www.portfolio-mheepooh.online
ADMIN_API_KEY=CHANGE_ME_STRONG_ADMIN_KEY
DISCORD_WEBHOOK_URL=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120
POSTS_CACHE_TTL_MS=10000
MONGO_INITDB_ROOT_USERNAME=portfolio_api
MONGO_INITDB_ROOT_PASSWORD=CHANGE_ME_STRONG_PASSWORD
